# Frontend
PUBLIC_SITE_URL=https://spgutils.ru
PUBLIC_BRAND_NAME=SPG Utils

# Worker / OAuth
WORKER_BASE_URL=https://api.spgutils.ru
OAUTH_ENCRYPTION_SECRET=replace-with-32-byte-secret
APP_SESSION_SECRET=replace-with-32-byte-secret

# TikTok OAuth
TIKTOK_CLIENT_ID=replace-me
TIKTOK_CLIENT_SECRET=replace-me
TIKTOK_AUTH_URL=https://open-api.tiktok.com/platform/oauth/connect/
TIKTOK_TOKEN_URL=https://open-api.tiktok.com/oauth/access_token/
TIKTOK_SCOPES=user.info.basic,video.publish,video.upload
TIKTOK_REDIRECT_URI=https://api.spgutils.ru/api/tiktok/callback

# Meta OAuth
META_APP_ID=replace-me
META_APP_SECRET=replace-me
META_AUTH_URL=https://www.facebook.com/v20.0/dialog/oauth
META_TOKEN_URL=https://graph.facebook.com/v20.0/oauth/access_token
META_LONG_LIVED_TOKEN_URL=https://graph.facebook.com/v20.0/oauth/access_token
META_SCOPES=pages_show_list,pages_read_engagement,pages_manage_posts,business_management,instagram_basic,instagram_content_publish
META_REDIRECT_URI=https://api.spgutils.ru/api/meta/callback

# Worker storage
OAUTH_STATE_KV=spgutils-oauth-state
OAUTH_SESSION_KV=spgutils-oauth-session
APP_LINKS_D1=spgutils_links

# Optional telemetry / support
SUPPORT_EMAIL=support@spgutils.ru
STATUS_EMAIL=status@spgutils.ru
