---
import Layout from '@/components/Layout.astro';
import ReviewPage from '@/components/ReviewPage.astro';

const successPlatform =
  Astro.url.searchParams.get('tiktok') === 'success'
    ? 'tiktok'
    : Astro.url.searchParams.get('meta') === 'success'
      ? 'meta'
      : null;
---

<Layout
  title="Review | SPG Utils"
  description="Review OAuth entry для TikTok и Meta, а Telegram bot является основным способом подключения."
  locale="ru"
  path="ru/review"
  canonical="https://spgutils.ru/ru/review"
  noindex={true}
>
  <ReviewPage locale="ru" successPlatform={successPlatform} />
</Layout>
