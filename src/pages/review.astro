---
import Layout from '@/components/Layout.astro';
import ReviewPage from '@/components/ReviewPage.astro';

const successPlatform =
  Astro.url.searchParams.get('tiktok') === 'success'
    ? 'tiktok'
    : Astro.url.searchParams.get('meta') === 'success'
      ? 'meta'
      : null;
---

<Layout
  title="Review | SPG Utils"
  description="Review OAuth entry for TikTok and Meta, with Telegram bot as the main linking path."
  locale="en"
  path="review"
  canonical="https://spgutils.ru/review"
  noindex={true}
>
  <ReviewPage locale="en" successPlatform={successPlatform} />
</Layout>
