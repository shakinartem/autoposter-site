---
type Locale = 'en' | 'ru';
type Platform = 'tiktok' | 'meta';

type Props = {
  locale: Locale;
  successPlatform?: Platform | null;
};

const { locale, successPlatform = null } = Astro.props as Props;

const apiBaseUrl = 'https://api.spgutils.ru';
const botUsername = import.meta.env.PUBLIC_TELEGRAM_BOT_USERNAME ?? '<BOT_USERNAME>';
const telegramBotUrl = botUsername && !botUsername.startsWith('<') ? `https://t.me/${botUsername}` : 'https://t.me/';

const connectUrls: Record<Platform, string> = {
  tiktok: `${apiBaseUrl}/api/oauth/tiktok/start`,
  meta: `${apiBaseUrl}/api/oauth/meta/start`
};

const labels = {
  en: {
    eyebrow: 'Review connection',
    title: 'Review OAuth entry for TikTok and Meta.',
    lead:
      'For working account linking, use the Telegram bot. These buttons are for review and testing flow only.',
    success: {
      tiktok:
        'TikTok connected successfully. Authorization successful. If you started from Telegram, return to the bot to continue.',
      meta:
        'Meta connected successfully. Authorization successful. If you started from Telegram, return to the bot to continue.'
    },
    botCta: 'Open Telegram Bot',
    reviewCards: {
      tiktok: {
        title: 'TikTok',
        body: 'Open the server-side OAuth flow for TikTok and finish the review/testing connection.',
        button: 'Connect TikTok'
      },
      meta: {
        title: 'Meta',
        body: 'Open the server-side OAuth flow for Meta and finish the review/testing connection.',
        button: 'Connect Meta'
      }
    },
    linking: {
      title: 'How account linking works',
      items: [
        'Open the Telegram bot.',
        'Choose Add account.',
        'Select TikTok or Meta.',
        'Complete OAuth authorization.',
        'Return to Telegram automatically.',
        'Manage publishing from the bot.'
      ]
    },
    notes: [
      'No client secret is placed in the frontend.',
      'Tokens stay server-side in the Worker or D1.',
      'The site is only for review, testing, and legal pages.'
    ],
    links: [
      { label: 'Privacy policy', href: '/privacy-policy' },
      { label: 'Terms', href: '/terms-of-service' },
      { label: 'Data deletion', href: '/data-deletion' }
    ]
  },
  ru: {
    eyebrow: 'Review connection',
    title: 'Review OAuth entry для TikTok и Meta.',
    lead:
      'Для рабочего подключения аккаунта используйте Telegram bot. Эти кнопки предназначены для review/testing flow.',
    success: {
      tiktok:
        'TikTok успешно подключён. Authorization successful. If you started from Telegram, return to the bot to continue.',
      meta:
        'Meta успешно подключён. Authorization successful. If you started from Telegram, return to the bot to continue.'
    },
    botCta: 'Открыть Telegram-бота',
    reviewCards: {
      tiktok: {
        title: 'TikTok',
        body: 'Откройте server-side OAuth flow для TikTok и завершите review/testing подключение.',
        button: 'Connect TikTok'
      },
      meta: {
        title: 'Meta',
        body: 'Откройте server-side OAuth flow для Meta и завершите review/testing подключение.',
        button: 'Connect Meta'
      }
    },
    linking: {
      title: 'Как работает подключение аккаунта',
      items: [
        'Откройте Telegram-бота.',
        'Нажмите Добавить аккаунт.',
        'Выберите TikTok или Meta.',
        'Пройдите OAuth-авторизацию.',
        'Вернитесь в Telegram автоматически.',
        'Управляйте публикациями из бота.'
      ]
    },
    notes: [
      'Client secret не попадает во frontend.',
      'Токены остаются только на сервере в Worker или D1.',
      'Сайт нужен только для review, testing и legal-страниц.'
    ],
    links: [
      { label: 'Privacy policy', href: '/ru/privacy-policy' },
      { label: 'Terms', href: '/ru/terms-of-service' },
      { label: 'Data deletion', href: '/ru/data-deletion' }
    ]
  }
} as const;

const text = labels[locale];
const successMessage = successPlatform ? text.success[successPlatform] : null;
---

<section class="hero review-hero">
  <p class="eyebrow">{text.eyebrow}</p>
  <h1>{text.title}</h1>
  <p class="lead">{text.lead}</p>
  <div class="hero-actions">
    <a class="button primary" href={telegramBotUrl}>{text.botCta}</a>
  </div>
  {successMessage ? (
    <div class="panel review-banner">
      <span class="chip">Success</span>
      <h2>{successMessage}</h2>
    </div>
  ) : null}
</section>

<section class="section">
  <div class="review-actions">
    <article class="panel review-card">
      <span class="chip">TikTok</span>
      <h2>{text.reviewCards.tiktok.title}</h2>
      <p>{text.reviewCards.tiktok.body}</p>
      <a class="button primary" href={connectUrls.tiktok}>{text.reviewCards.tiktok.button}</a>
    </article>
    <article class="panel review-card">
      <span class="chip">Meta</span>
      <h2>{text.reviewCards.meta.title}</h2>
      <p>{text.reviewCards.meta.body}</p>
      <a class="button primary" href={connectUrls.meta}>{text.reviewCards.meta.button}</a>
    </article>
  </div>
</section>

<section class="section">
  <div class="cards-grid review-grid">
    <article class="panel">
      <h2>{text.linking.title}</h2>
      <ul class="clean-list">
        {text.linking.items.map((item) => <li>{item}</li>)}
      </ul>
    </article>
    <article class="panel">
      <h2>{locale === 'ru' ? 'Безопасность' : 'Safety'}</h2>
      <ul class="clean-list">
        {text.notes.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </div>
</section>

<section class="section">
  <div class="panel subtle review-links">
    {text.links.map((item) => (
      <a href={item.href}>{item.label}</a>
    ))}
  </div>
</section>
